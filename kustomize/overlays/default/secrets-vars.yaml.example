# Example secrets configuration file for the default overlay.
#
# Copy this file to secrets-vars.yaml and update with your actual values:
#   cp secrets-vars.yaml.example secrets-vars.yaml
#
# WARNING: secrets-vars.yaml contains sensitive data and should NOT be committed to git!
# It is already included in .gitignore.
#
# This overlay uses all local in-cluster infrastructure (postgres, redis, rabbitmq, minio, opensearch).
# Connection strings point to in-cluster service names.

apiVersion: v1
kind: Secret
metadata:
  name: overlay-secret-vars
  annotations:
    config.kubernetes.io/local-config: "true"
type: Opaque
stringData:
  # ── Database ──────────────────────────────────────────────────────────────────
  # In-cluster postgres service. Update credentials to match your postgres component config.
  DATABASE_URL: "postgresql://<db-user>:<db-password>@plane-postgres:5432/plane"

  # ── Message broker ────────────────────────────────────────────────────────────
  # In-cluster rabbitmq service. Update credentials to match your rabbitmq component config.
  AMQP_URL: "amqp://<mq-user>:<mq-password>@plane-rabbitmq:5672/"

  # ── Cache ─────────────────────────────────────────────────────────────────────
  # In-cluster redis service.
  REDIS_URL: "redis://plane-redis:6379/0"

  # ── Object storage (MinIO) ────────────────────────────────────────────────────
  # Matches MINIO_ROOT_USER / MINIO_ROOT_PASSWORD set in the minio component.
  # Default minio component values: user=admin, password=password — change these!
  AWS_ACCESS_KEY_ID: "<minio-root-user>"
  AWS_SECRET_ACCESS_KEY: "<minio-root-password>"
  AWS_S3_ENDPOINT_URL: "http://plane-minio:9000"
  AWS_S3_BUCKET_NAME: "plane-bucket"
  AWS_REGION: "us-east-1"
  USE_MINIO: "1"
  # Maximum file upload size in bytes (5242880 = 5MB)
  FILE_SIZE_LIMIT: "5242880"

  # ── OpenSearch ────────────────────────────────────────────────────────────────
  OPENSEARCH_ENABLED: "1"
  OPENSEARCH_URL: "http://plane-opensearch:9200"
  # Only needed when the opensearch-external-auth component is enabled:
  # OPENSEARCH_USERNAME: "plane"
  # OPENSEARCH_PASSWORD: "your-opensearch-password"

  # ── Application secrets ───────────────────────────────────────────────────────
  # Generate new random values before deploying:
  #   openssl rand -hex 32
  SECRET_KEY: "GENERATE-A-RANDOM-64-HEX-STRING"
  AES_SECRET_KEY: "GENERATE-A-RANDOM-32-CHARACTER-STRING"
  LIVE_SERVER_SECRET_KEY: "GENERATE-A-RANDOM-64-HEX-STRING"
