# Example variables configuration file
# 
# Copy this file to vars.yaml if it doesn't exist:
#   cp vars.yaml.example vars.yaml
# 
# This file contains non-sensitive configuration values
# It's safe to commit to git (unlike secrets-vars.yaml)

apiVersion: v1
kind: ConfigMap
metadata:
  name: overlay-vars
  annotations:
    config.kubernetes.io/local-config: "true"
data:
  # Application version used across all images and config
  APP_VERSION: "v2.3.4"
  
  # Domain configuration (without protocol)
  APP_DOMAIN: "plane.mycompany.com"
  
  # Web URL (with protocol - http for dev, https for production)
  WEB_URL: "http://plane.mycompany.com"
  
  # CORS allowed origins (comma-separated, both http and https)
  CORS_ALLOWED_ORIGINS: "http://plane.mycompany.com,https://plane.mycompany.com"
  
  # Ingress class (nginx, traefik-external, alb, etc.)
  INGRESS_CLASS: "nginx"
  
  # AWS ALB SSL Certificate ARN (required when using ALB ingress controller)
  # Example: "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"
  ALB_SSL_CERT_ARN: ""
  
  # Deployment configuration
  IS_AIRGAPPED: "0"  # Set to "1" for air-gapped deployments

  # Optional: AWS Secrets Manager ARNs (non-sensitive, used to fetch credentials)
  AMAZONMQ_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-mq-secret"
  ELASTICACHE_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-redis-secret"
  RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-rds-secret"

  # Pi service - AWS Secrets Manager ARNs (distinct from main plane ARNs)
  PI_RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-rds-secret"
  PI_FOLLOWER_RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-follower-rds-secret"
  PI_AMAZONMQ_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-mq-secret"
  PI_MODEL_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-model-secret"

  # Pi service - AI provider config
  PI_OPENSEARCH_ML_MODEL_ID: "4lRq0ZwB0CqWNiURy_vi"
  PI_EMBEDDING_MODEL: "bedrock/amazon.titan-embed-text-v1"
  PI_CUSTOM_LLM_ENABLED: "true"
  PI_CUSTOM_LLM_PROVIDER: "bedrock"
  PI_CUSTOM_LLM_MODEL_KEY: "global.anthropic.claude-sonnet-4-6"
  PI_CUSTOM_LLM_NAME: "claude-sonnet-4-6"
  PI_CUSTOM_LLM_AWS_REGION: "us-east-2"

  # Secrets Manager credential cache TTL in seconds (applies to api, silo, live, pi)
  AWS_SECRET_CACHE_TTL: "300"

  # Optional: EKS IRSA for Plane workloads (ServiceAccount annotation)
  PLANE_SERVICE_ACCOUNT_ROLE_ARN: "arn:aws:iam::123456789012:role/PlaneS3Role"
