# Secrets configuration for this overlay.
#
# WARNING: This file contains sensitive credentials.
# Do NOT commit it to git — it is already in .gitignore.
# Copy secrets-vars.yaml.example to secrets-vars.yaml and fill in real values.

apiVersion: v1
kind: Secret
metadata:
  name: overlay-secret-vars
  annotations:
    config.kubernetes.io/local-config: "true"
type: Opaque
stringData:
  # ── Database (AWS RDS) ────────────────────────────────────────────────────────
  # Required: enable component static-db-url (already on by default in this overlay)
  DATABASE_URL: "postgresql://plane:password@your-rds-instance.us-east-1.rds.amazonaws.com:5432/plane"

  # ── Message broker (Amazon MQ) ────────────────────────────────────────────────
  AMQP_URL: "amqps://plane:password@your-amazonmq.mq.us-east-1.amazonaws.com:5671/"

  # ── Cache (Amazon ElastiCache) ────────────────────────────────────────────────
  REDIS_URL: "redis://your-cluster.cache.amazonaws.com:6379/0"

  # ── Object storage (AWS S3) ───────────────────────────────────────────────────
  # Required: enable component s3-static-credentials (already on by default in this overlay)
  AWS_ACCESS_KEY_ID: "your-access-key-id"
  AWS_SECRET_ACCESS_KEY: "your-secret-access-key"
  # Leave empty to use the default AWS S3 endpoint for the configured region
  AWS_S3_ENDPOINT_URL: ""
  AWS_S3_BUCKET_NAME: "your-plane-bucket"
  AWS_REGION: "us-east-1"
  USE_MINIO: "0"
  # Maximum file upload size in bytes (default: 5242880 = 5MB)
  FILE_SIZE_LIMIT: "5242880"

  # ── OpenSearch (Amazon OpenSearch Service) ────────────────────────────────────
  OPENSEARCH_ENABLED: "1"
  OPENSEARCH_URL: "https://your-domain.us-east-1.es.amazonaws.com"
  # Only needed when component opensearch-external-auth is enabled:
  # OPENSEARCH_USERNAME: "your-opensearch-username"
  # OPENSEARCH_PASSWORD: "your-opensearch-password"

  # ── Application secrets ───────────────────────────────────────────────────────
  # Generate with: openssl rand -hex 32
  SECRET_KEY: "CHANGE_ME_openssl_rand_hex_32"
  AES_SECRET_KEY: "CHANGE_ME_32_chars"
  LIVE_SERVER_SECRET_KEY: "CHANGE_ME_openssl_rand_hex_32"
