# This ConfigMap holds all the variables for this overlay.
# It is NOT deployed to the cluster — it is only used as a source for replacements.
apiVersion: v1
kind: ConfigMap
metadata:
  name: overlay-vars
  annotations:
    config.kubernetes.io/local-config: "true"
data:
  # Application version used across all images and config
  APP_VERSION: "latest"

  # Domain configuration
  APP_DOMAIN: "plane.example.com"

  # Web URL (with protocol)
  WEB_URL: "https://plane.example.com"

  # CORS allowed origins (comma-separated)
  CORS_ALLOWED_ORIGINS: "http://plane.example.com,https://plane.example.com"

  # Allow all attachment types (leave empty to use default restrictions, set to "1" to allow all)
  ALLOW_ALL_ATTACHMENT_TYPES: "1"

  # Ingress class
  INGRESS_CLASS: "nginx"

  # Other configuration flags
  IS_AIRGAPPED: "0"

  # Storage class for monitor StatefulSet PVC (e.g. gp2, gp3, standard)
  MONITOR_STORAGE_CLASS: "gp2"

  # OpenSearch configuration
  OPENSEARCH_INDEX_PREFIX: "plane"
  PRIME_HOST: "https://preview.prime.plane.so"
