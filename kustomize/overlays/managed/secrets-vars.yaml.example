# Example secrets configuration file for the managed overlay.
#
# Copy this file to secrets-vars.yaml and update with your actual values:
#   cp secrets-vars.yaml.example secrets-vars.yaml
#
# WARNING: secrets-vars.yaml contains sensitive data and should NOT be committed to git!
# It is already included in .gitignore.
#
# This overlay connects to external managed services: RDS (Postgres), ElastiCache (Redis),
# Amazon MQ (RabbitMQ-compatible AMQP), S3, and Amazon OpenSearch Service.

apiVersion: v1
kind: Secret
metadata:
  name: overlay-secret-vars
  annotations:
    config.kubernetes.io/local-config: "true"
type: Opaque
stringData:
  # ── Database (AWS RDS) ────────────────────────────────────────────────────────
  # Required when component static-db-url is enabled (default in this overlay).
  DATABASE_URL: "postgresql://<db-user>:<db-password>@your-rds-instance.us-east-1.rds.amazonaws.com:5432/plane"

  # ── Message broker (Amazon MQ) ────────────────────────────────────────────────
  # AmazonMQ uses port 5671 (AMQP over TLS) by default
  AMQP_URL: "amqps://<mq-user>:<mq-password>@your-amazonmq.mq.us-east-1.amazonaws.com:5671/"

  # ── Cache (Amazon ElastiCache) ────────────────────────────────────────────────
  REDIS_URL: "your-cluster.cache.amazonaws.com:6379/0"

  # ── Object storage (AWS S3) ───────────────────────────────────────────────────
  # Required when component s3-static-credentials is enabled (default in this overlay).
  AWS_ACCESS_KEY_ID: "<your-access-key-id>"
  AWS_SECRET_ACCESS_KEY: "<your-secret-access-key>"
  # Leave empty to use the default AWS S3 endpoint for the configured region
  AWS_S3_ENDPOINT_URL: ""
  AWS_S3_BUCKET_NAME: "<your-plane-bucket>"
  AWS_REGION: "us-east-1"
  USE_MINIO: "0"
  # Maximum file upload size in bytes (5242880 = 5MB)
  FILE_SIZE_LIMIT: "5242880"

  # ── OpenSearch (Amazon OpenSearch Service) ────────────────────────────────────
  OPENSEARCH_ENABLED: "1"
  OPENSEARCH_URL: "https://your-domain.us-east-1.es.amazonaws.com"
  # Only needed when component opensearch-external-auth is enabled:
  # OPENSEARCH_USERNAME: "<your-opensearch-username>"
  # OPENSEARCH_PASSWORD: "<your-opensearch-password>"

  # ── Application secrets ───────────────────────────────────────────────────────
  # Generate new random values before deploying:
  #   openssl rand -hex 32
  SECRET_KEY: "GENERATE-A-RANDOM-64-HEX-STRING"
  AES_SECRET_KEY: "GENERATE-A-RANDOM-32-CHARACTER-STRING"
  LIVE_SERVER_SECRET_KEY: "GENERATE-A-RANDOM-64-HEX-STRING"
