# Example secrets configuration file
# 
# Copy this file to secrets-vars.yaml and update with your actual values:
#   cp secrets-vars.yaml.example secrets-vars.yaml
# 
# WARNING: secrets-vars.yaml contains sensitive data and should NOT be committed to git!
# It's already included in .gitignore

apiVersion: v1
kind: Secret
metadata:
  name: overlay-secret-vars
  annotations:
    config.kubernetes.io/local-config: "true"
type: Opaque
stringData:
  # Infrastructure Connection Strings
  # DATABASE_URL: optional - only needed when using static URL. Enable component static-db-url and set this.
  #   Omit or leave empty when using IRSA/EKS Pod Identity; app fetches DB URL from AWS Secrets Manager via RDS_SECRET_ARN in vars.yaml.
  DATABASE_URL: "postgresql://your-postgres-host:5432/plane"
  REDIS_URL: "redis://your-redis-host:6379/"
  AMQP_URL: "amqp://your-rabbitmq-host:5672/"

  # Pi service internal secret (shared between Plane and Pi)
  # Generate: openssl rand -hex 32
  PI_INTERNAL_SECRET: "GENERATE-A-RANDOM-64-HEX-STRING"
  
  # OpenSearch Configuration
  OPENSEARCH_ENABLED: "1"
  OPENSEARCH_URL: "http://your-opensearch-host:9200"
  # OPENSEARCH_USERNAME / OPENSEARCH_PASSWORD: only needed when component opensearch-external-auth is enabled (external OpenSearch with auth)
  OPENSEARCH_USERNAME: "your-opensearch-username"
  OPENSEARCH_PASSWORD: "your-opensearch-password"
  
  # MinIO / S3 Configuration
  # AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: only needed when component s3-static-credentials is enabled.
  #   Omit when using IRSA (eks-irsa-plane-serviceaccount) for S3 access.
  AWS_ACCESS_KEY_ID: "AKxxxxxxxxxxxxxxxxxxxxxx"
  AWS_SECRET_ACCESS_KEY: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  AWS_S3_ENDPOINT_URL: "https://s3.us-east-1.amazonaws.com"
  AWS_S3_BUCKET_NAME: "plane-uploads"
  AWS_REGION: "us-east-1"
  
  # AWS Secrets Manager ARNs (contain account ID — keep secret)
  ELASTICACHE_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-redis-secret"
  RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-rds-secret"
  AMAZONMQ_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-mq-secret"

  # Pi service - AWS Secrets Manager ARNs
  PI_RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-rds-secret"
  PI_FOLLOWER_RDS_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-follower-rds-secret"
  PI_AMAZONMQ_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-mq-secret"
  PI_MODEL_SECRET_ARN: "arn:aws:secretsmanager:us-east-1:123456789012:secret:your-pi-model-secret"

  # EKS IRSA role ARN (contains account ID — keep secret)
  PLANE_SERVICE_ACCOUNT_ROLE_ARN: "arn:aws:iam::123456789012:role/PlaneWorkloadRole"

  # Application Secrets (IMPORTANT: Generate new random values!)
  # Generate random secret keys with:
  #   openssl rand -hex 32
  SECRET_KEY: "GENERATE-A-RANDOM-50-CHARACTER-STRING"
  AES_SECRET_KEY: "GENERATE-A-RANDOM-32-CHARACTER-STRING"  
  LIVE_SERVER_SECRET_KEY: "GENERATE-A-RANDOM-42-CHARACTER-STRING"
